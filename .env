# ─────────────────────────────────────────────────────────────
#  ChurnMaster Pro — Environment Variables
# ─────────────────────────────────────────────────────────────

# Flask secret key — CHANGE THIS before deploying publicly
SECRET_KEY=churnmaster-dev-key-change-in-production

# Server port
PORT=5000

# Debug mode (set to false in production)
FLASK_DEBUG=true

# ─── Power BI Live API Token ──────────────────────────────────
# If set, /api/powerbi_live requires ?token=THIS_VALUE
# If left empty, the endpoint is open (fine for localhost)
# Use this URL in Power BI Desktop:
#   http://localhost:5000/api/powerbi_live/records?token=YOUR_TOKEN_HERE
POWERBI_TOKEN=

# ─── Example token (uncomment and set your own) ───────────────
# POWERBI_TOKEN=my_very_secret_token_2026_change_this
