# ─────────────────────────────────────────────────────────────────────────
#  ChurnMaster Pro — Environment Variables
#  Copy this file to .env for local development.
#  For Vercel: add these in Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — Flask session secret key
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# OPTIONAL — Power BI live API token
# If set, /api/powerbi_live requires ?token=THIS_VALUE
# Leave empty to keep the endpoint open
POWERBI_TOKEN=

# ── Local-only variables (not needed on Vercel) ───────────────────────────
PORT=5000
FLASK_DEBUG=false
